:root {
    --primary-pink: #ff80ab;
    --soft-pink: #fce4ec;
    --deep-rose: #d81b60;
    --alert-red: #ffe4e1;
    --white: #ffffff;
}

body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background-color: #fff9fb;
    margin: 0;
    color: #333;
}

/* Navigation 🎀 */
nav {
    background-color: var(--white);
    padding: 15px 30px;
    box-shadow: 0 2px 10px rgba(255, 128, 171, 0.2);
}

nav ul {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    justify-content: center;
}

nav ul li a {
    text-decoration: none;
    color: var(--deep-rose);
    font-weight: bold;
    padding: 10px 20px;
    transition: 0.3s;
}

nav ul li a:hover { color: var(--primary-pink); }

/* Containers & Cards 📦 */
.container { padding: 40px; max-width: 1100px; margin: auto; }

.card {
    background: var(--white);
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    margin-bottom: 20px;
    border: 1px solid var(--soft-pink);
}

/* Tables 📋 */
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
}

th { background-color: var(--primary-pink); color: white; padding: 12px; }
td { padding: 12px; border-bottom: 1px solid var(--soft-pink); text-align: center; }

/* Buttons & Forms 🎀 */
button, .btn {
    background-color: var(--primary-pink);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 25px;
    cursor: pointer;
    font-weight: bold;
    transition: 0.3s;
}

button:hover { background-color: var(--deep-rose); }

input, select {
    padding: 10px;
    border: 1px solid var(--soft-pink);
    border-radius: 8px;
    margin: 5px 0;
}

.overdue-flag { background-color: var(--alert-red) !important; }