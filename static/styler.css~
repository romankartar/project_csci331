:root {
    --primary-pink: #ff80ab;
    --soft-pink: #fce4ec;
    --deep-rose: #d81b60;
    --alert-red: #ffe4e1;
    --white: #ffffff;
    
    /* New Blue colour 💎 */
    --primary-blue: #23869eff; 
    --soft-blue: #e0f2f1;
    --deep-blue: #1a6577;
}

body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background-color: #fff9fb;
    margin: 0;
    color: #333;
    transition: background-color 0.3s ease;
}

/* --- Navigation 🎀 --- */
nav {
    background-color: var(--white);
    padding: 15px 30px;
    box-shadow: 0 2px 10px rgba(255, 128, 171, 0.2);
}

nav ul {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    justify-content: center;
}

nav ul li a {
    text-decoration: none;
    color: var(--deep-rose);
    font-weight: bold;
    padding: 10px 20px;
    transition: 0.3s;
}

nav ul li a:hover { color: var(--primary-pink); }

/* --- Containers & Cards --- */
.container { padding: 40px; max-width: 1100px; margin: auto; }

.card {
    background: var(--white);
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    margin-bottom: 20px;
    border: 1px solid var(--soft-pink);
}

/* --- Tables --- */
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
}

th { background-color: var(--primary-pink); color: white; padding: 12px; }
td { padding: 12px; border-bottom: 1px solid var(--soft-pink); text-align: center; }

/* --- Buttons & Forms --- */
button, .btn {
    background-color: var(--primary-pink);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 25px;
    cursor: pointer;
    font-weight: bold;
    transition: 0.3s;
}

button:hover { background-color: var(--deep-rose); }

input, select {
    padding: 10px;
    border: 1px solid var(--soft-pink);
    border-radius: 8px;
    margin: 5px 0;
}

/* --- Status & Alerts 🚨 --- */
.overdue-flag { background-color: var(--alert-red) !important; }

.flash-message { font-weight: bold; margin-bottom: 5px; }
.flash-message.error { color: red; padding-left: 50px; }
.flash-message.success { text-align: center; color: green; }

/* --- Special Buttons --- */
.lunchButton {
    background-color: plum;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 25px;
    cursor: pointer;
    font-weight: bold;
    transition: 0.3s;
}

.lunchButton:hover { background-color: rgb(185, 45, 185); }

/* =========================================
   NEW: Professional Blue Theme Overrides 💎
   (Only applies when <body class="blue-theme">)
   ========================================= */

.blue-theme { background-color: #f0f7f9; } /* Light blue bg */

.blue-theme nav { box-shadow: 0 2px 10px rgba(35, 134, 158, 0.2); }
.blue-theme nav ul li a { color: var(--primary-blue); }
.blue-theme nav ul li a:hover { color: var(--deep-blue); }

.blue-theme th { background-color: var(--primary-blue); }
.blue-theme button, .blue-theme .btn { background-color: var(--primary-blue); }
.blue-theme button:hover { background-color: var(--deep-blue); }

.blue-theme .card { border: 1px solid var(--soft-blue); }

/* Keep overdue flag pink for high visibility! */
.blue-theme .overdue-flag { 
    background-color: var(--alert-red) !important; 
    border-left: 5px solid var(--primary-pink);
}

h2 { text-align: center; margin-top: 20px; }