<!DOCTYPE html>
<html>
<head>
    <title>Clinic Dashboard</title>
    <link rel="stylesheet" type="text/css" href="/static/styler.css">
    <style>
        /* The Red Flag style from  requirements  */
        .overdue-flag {
            background-color: #ffe4e1 !important; /* Misty Rose */
            border-left: 5px solid #ff80ab;
        }
        .status-scheduled { color: #d81b60; font-weight: bold; }
        .status-completed { color: #4caf50; }
    </style>
</head>
<body>

<nav>
    <ul>
        <li><a href="/home">Home</a></li>
        <li><a href="/patients">Patients</a></li>
        <li><a href="/surgeries">Surgeries</a></li>
        <li><a href="/scheduling">Scheduling</a></li> <!-- Added for Milestone 2! -->
        <li><a href="/prescriptions">Prescriptions</a></li>
        <li><a href="/staff">Staff</a></li>
        <li><a href="/logout">Logout</a></li>
    </ul>
</nav>

<h1>Clinic Dashboard</h1>
<p>Welcome, {{ session['user_name'] }}! You are logged in as a <strong>{{ session['role'] }}</strong>.</p>
<p>Viewing Schedule for: <strong>{{ display_date }}</strong> </p>

<section>
    <h2>Today's Surgical Schedule </h2>
    <table border="1" style="width:100%; border-collapse: collapse;">
        <thead>
            <tr style="background-color: #ff80ab; color: white;">
            	 <th>Date</th> <!-- Added this! -->
                <th>Time</th>
                <th>Surgery ID</th>
                <th>Surgery Name</th>
                <th>Assigned Staff 👩‍⚕️</th> <!-- New Column! -->
                <th>Room</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for surgery in surgeries %}
            <!-- Logic: If time is past and not completed, apply the Misty Rose class! -->
            <tr class="{{ 'overdue-flag' if surgery.timeScheduled < current_time and surgery.status != 'completed' else '' }}">
                <td>{{ surgery.date }}</td> <!-- Added this! -->
    				 <td>{{ surgery.timeScheduled }}</td>
   				 <td>{{ surgery.surgeryID }}</td>
    				 <td>{{ surgery.surgeryName }}</td>
    				 <td>{{ surgery.staffIDs }}</td> 
    				 <td>Room {{ surgery.surgeryRoom }}</td>
    				 <!-- Dynamic Status Styling -->
        <td>
            {% if surgery.status == 'completed' %}
                <span style="color: green;">  Completed</span>
            {% else %}
                <span style ="color: {{ 'red' if surgery.timeScheduled < current_time else 'blue' }};">
                   {{ ' LATE' if surgery.timeScheduled < current_time else ' Scheduled' }}
                </span>
            {% endif %}
        </td>
    <% endfor %>
    </tr> 
</tbody>
    </table>
</section>

</body>
</html>